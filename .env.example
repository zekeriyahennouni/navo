# Kopiere diese Datei zu ".env" (lokal) oder trage die Werte bei Render als
# "Environment Variables" ein. Committe NIEMALS deinen echten Key.

# Dein Anthropic-API-Key (Pflicht). Bekommst du unter console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-hier-deinen-key-einsetzen

# Optional: Modell. Standard ist claude-sonnet-5.
# Guenstiger/schneller z. B. claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-5

# Optional: Port (Render setzt das automatisch)
PORT=3000
